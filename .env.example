# === OBLIGATOIRE ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXX

# === SOURCES ===
# Valeurs possibles : linkedin, hellowork, wtj (séparées par des virgules)
JOB_SOURCES=linkedin,hellowork,wtj

# === ZONE DE RECHERCHE ===
JOB_LOCATION=Moulins, Allier
JOB_RADIUS_KM=150

# === FILTRES DE CONTRAT ===
# L'offre doit contenir au moins un de ces termes
ALTERNANCE_REQUIRED_TERMS=alternance,apprentissage
# L'offre est rejetée si elle contient un de ces termes
EXCLUDED_JOB_TERMS=stage,internship,cdi,cdd,freelance,interim,intérim

# === LINKEDIN ===
# Nombre de pages par mot-clé (25 offres/page)
LINKEDIN_MAX_PAGES=2

# === PLANIFICATION ===
CHECK_INTERVAL_HOURS=6
